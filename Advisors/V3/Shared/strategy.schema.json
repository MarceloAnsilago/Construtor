{
  "schema_version": 2,
  "properties": {
    "strategy.name": {
      "type": "string",
      "default": "Minha estrategia"
    },
    "strategy.magic_number": {
      "type": "string",
      "default": "100000"
    },
    "signals.order_mode": {
      "type": "string",
      "default": "Mercado",
      "enum": ["Mercado", "Limite"]
    },
    "signals.limit_mode": {
      "type": "string",
      "default": "Referencia",
      "enum": ["Referencia", "Media"]
    },
    "signals.limit_reference.base": {
      "type": "string",
      "default": "Maxima",
      "enum": ["Maxima", "Minima", "Abertura", "Fechamento"]
    },
    "signals.limit_reference.candle": {
      "type": "string",
      "default": "Atual",
      "enum": ["Atual", "Ultimo", "Penultimo", "Antepenultimo"]
    },
    "signals.limit_reference.move_next_candle": {
      "type": "bool",
      "default": false
    },
    "signals.limit_reference.distance": {
      "type": "string",
      "default": "0"
    },
    "signals.limit_reference.expire": {
      "type": "string",
      "default": "Nao expirar",
      "enum": ["Nao expirar", "1 candle", "2 candles", "3 candles", "4 candles"]
    },
    "signals.filter.enabled": {
      "type": "bool",
      "default": false
    },
    "signals.filter.measure": {
      "type": "string",
      "default": "Pontos",
      "enum": ["Pontos", "Percentual"]
    },
    "signals.filter.timeframe": {
      "type": "string",
      "default": "Corrente"
    },
    "signals.filter.candle_min": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.candle_max": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.body_min": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.body_max": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.upper_wick_min": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.upper_wick_max": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.lower_wick_min": {
      "type": "string",
      "default": "0"
    },
    "signals.filter.lower_wick_max": {
      "type": "string",
      "default": "0"
    },
    "signals.channels.enabled": {
      "type": "bool",
      "default": false
    },
    "signals.channels.indicator": {
      "type": "string",
      "default": "Bandas de Bollinger",
      "enum": ["Bandas de Bollinger", "Envelopes", "Keltner", "Donchian", "Canal ATR"]
    },
    "signals.channels.signal": {
      "type": "string",
      "default": "Fechou fora",
      "enum": ["Fechou fora", "Toque", "Fechou fora e voltou", "Fechou dentro e saiu", "Estando fora"]
    },
    "signals.channels.period": {
      "type": "string",
      "default": "20"
    },
    "signals.channels.deviation": {
      "type": "string",
      "default": "2.0"
    },
    "signals.channels.shift": {
      "type": "string",
      "default": "0"
    },
    "signals.channels.price": {
      "type": "string",
      "default": "Fechamento",
      "enum": ["Fechamento", "Abertura", "Maximo", "Minimo", "Mediano", "Tipico", "Medio"]
    },
    "risk.allow_buy": {
      "type": "string",
      "default": "Sim",
      "enum": ["Sim", "Nao"]
    },
    "risk.allow_sell": {
      "type": "string",
      "default": "Sim",
      "enum": ["Sim", "Nao"]
    },
    "risk.initial_volume": {
      "type": "string",
      "default": "100"
    },
    "risk.max_spread": {
      "type": "string",
      "default": "100"
    }
  }
}
